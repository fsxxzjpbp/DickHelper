    "icon": "./assets/icon.png",
    "android": {
      "package": "com.dickhelper.mobile",
      "versionCode": 1,
      "predictiveBackGestureEnabled": true
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-sharing",
      "expo-status-bar"
    ]
  }
